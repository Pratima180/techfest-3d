// 1,800 colored points + 8 floating wireframe polyhedra
// Rotates slowly, reacts to mouse position and scroll offset
const particleMat = new THREE.PointsMaterial({ size: 0.04, vertexColors: true });
const particles = new THREE.Points(particleGeo, particleMat);

function animateBg(t) {
  particles.rotation.y = t * 0.00004;
  particles.rotation.x = scrollY * 0.0003;
  bgCamera.position.x += (bgMouseX * 0.5 - bgCamera.position.x) * 0.03; // smooth follow
  shapes.forEach(s => { s.rotation.x += s.userData.rotX; s.rotation.y += s.userData.rotY; });
  bgRenderer.render(bgScene, bgCamera);
  requestAnimationFrame(animateBg);
}
// Central sphere with wireframe overlay + 3 orbiting torus rings + 12 satellite cubes
// Drag to orbit, scroll to zoom, click sphere to pulse-flash it

demoCanvas.addEventListener('mousedown', e => { isDragging = true; });
demoCanvas.addEventListener('mousemove', e => {
  if (!isDragging) return;
  targetRot.y += (e.clientX - prevMouse.x) * 0.006;
  targetRot.x += (e.clientY - prevMouse.y) * 0.006;
});

