// Click pulse
demoCanvas.addEventListener('click', () => {
  if (hovering) {
    sphereMat.emissive = new THREE.Color(0x6c3bff);
    setTimeout(() => { sphereMat.emissive = new THREE.Color(0x000000); }, 300);
  }
});
function animateCounter(el, target, duration = 1800) {
  let start = null;
  function step(ts) {
    if (!start) start = ts;
    const eased = 1 - Math.pow(1 - Math.min((ts - start) / duration, 1), 3); // cubic ease-out
    el.textContent = Math.floor(eased * target).toLocaleString();
    if (eased < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

// Fires once when stat cards enter viewport
const io = new IntersectionObserver(entries => {
  if (entry.isIntersecting && !statsAnimated) {
    statsAnimated = true;
    statNums.forEach(el => animateCounter(el, parseInt(el.dataset.target)));
  }
}, { threshold: 0.15 });